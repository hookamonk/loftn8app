# ============================================================================
# LOFT№8 — SERVER (backend) environment
# ----------------------------------------------------------------------------
# This file documents EVERY variable the backend reads. On Render: open your
# backend Web Service → Environment → "Add from .env" and paste the filled-in
# values. The CLIENT is a SEPARATE Render service — its variables are listed at
# the very bottom of this file.
#
# Do NOT set PORT on Render — Render injects it automatically and the app reads
# it. Setting it yourself breaks Render's health check.
# ============================================================================

# --- Core (REQUIRED) --------------------------------------------------------
NODE_ENV=production

# Render Postgres: copy the *Internal* Database URL from your Render Postgres
# instance. Keep sslmode=require for external URLs.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Public URL of the CLIENT service (used for CORS). Example:
#   https://loftn8-client.onrender.com  or  https://app.your-domain.com
FRONTEND_ORIGIN=https://loftn8-client.onrender.com

# Three DIFFERENT random secrets, each >= 20 chars. Generate with:
#   openssl rand -base64 32
JWT_USER_SECRET=replace_me_random_32_chars_min
JWT_GUEST_SESSION_SECRET=replace_me_random_32_chars_min
JWT_STAFF_SECRET=replace_me_random_32_chars_min

# Leave EMPTY on Render. The client proxies /api → backend, so auth cookies are
# first-party to the client domain; a Domain value here would make the browser
# reject them. Only set this (e.g. .your-domain.com) if client and API share a
# parent custom domain (app.your-domain.com + api.your-domain.com).
COOKIE_DOMAIN=

# Auto-close a table session this many minutes after it's fully paid.
GUEST_SESSION_AUTO_END_AFTER_PAYMENT_MINUTES=30

# --- Web push notifications (REQUIRED for staff lock-screen alerts) ---------
# Without these, push is silently disabled (SSE + polling still work) and the
# server logs a warning at boot. Generate a key pair with:
#   cd server && npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@your-domain.com
VAPID_PUBLIC_KEY=replace_me_vapid_public_key
VAPID_PRIVATE_KEY=replace_me_vapid_private_key

# --- Email (REQUIRED in production for OTP & password reset) ----------------
# Without SMTP, registration/reset codes cannot be delivered. Codes are NEVER
# returned in the API response in production (security).
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=LOFT№8

# --- Optional ---------------------------------------------------------------
# Allow *.vercel.app preview origins to call the API with credentials. Keep
# false unless you specifically use Vercel previews.
ALLOW_VERCEL_PREVIEWS=false

# ============================================================================
# Staff seed accounts (used ONLY by `npm run prisma:seed`)
# ----------------------------------------------------------------------------
# Optional — if omitted, the seed falls back to weak defaults like
# garden_waiter / garden_waiter_1234. In PRODUCTION set strong passwords here,
# then run the seed once. One waiter / hookah / manager per venue.
# (There is no separate ADMIN seed; promote a manager to ADMIN in the DB if
# you need the admin/guests view.)
# ============================================================================
STAFF_ZIZKOV_WAITER_USERNAME=zizkov_waiter
STAFF_ZIZKOV_WAITER_PASSWORD=change_me_strong
STAFF_ZIZKOV_HOOKAH_USERNAME=zizkov_hookah
STAFF_ZIZKOV_HOOKAH_PASSWORD=change_me_strong
STAFF_ZIZKOV_MANAGER_USERNAME=zizkov_manager
STAFF_ZIZKOV_MANAGER_PASSWORD=change_me_strong

STAFF_GARDEN_WAITER_USERNAME=garden_waiter
STAFF_GARDEN_WAITER_PASSWORD=change_me_strong
STAFF_GARDEN_HOOKAH_USERNAME=garden_hookah
STAFF_GARDEN_HOOKAH_PASSWORD=change_me_strong
STAFF_GARDEN_MANAGER_USERNAME=garden_manager
STAFF_GARDEN_MANAGER_PASSWORD=change_me_strong

STAFF_NEKAZANKA_WAITER_USERNAME=nekazanka_waiter
STAFF_NEKAZANKA_WAITER_PASSWORD=change_me_strong
STAFF_NEKAZANKA_HOOKAH_USERNAME=nekazanka_hookah
STAFF_NEKAZANKA_HOOKAH_PASSWORD=change_me_strong
STAFF_NEKAZANKA_MANAGER_USERNAME=nekazanka_manager
STAFF_NEKAZANKA_MANAGER_PASSWORD=change_me_strong

# ============================================================================
# CLIENT (frontend) Render service — set these on the CLIENT service, NOT here:
#   NODE_ENV=production
#   NEXT_PUBLIC_API_BASE_URL=https://loftn8-app.onrender.com   <- your BACKEND URL
# The client calls /api/* and rewrites it to NEXT_PUBLIC_API_BASE_URL, so the
# browser only ever talks to the client origin (cookies stay first-party).
# ============================================================================
